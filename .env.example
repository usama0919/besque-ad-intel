# Copy this file to .env and fill in real values. Never commit .env.

# --- Database (dedupe, decisions, artifacts) ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/besque

# --- Claude (vision deconstruction + copy generation) ---
ANTHROPIC_API_KEY=sk-ant-your_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# --- Apify (Meta Ad Library scrape) ---
APIFY_TOKEN=apify_api_your_token_here
APIFY_ACTOR_ID=automly/facebook-ad-library-scraper

# --- Replicate (Flux single-pass draft image) ---
REPLICATE_API_TOKEN=r8_your_token_here
IMAGE_MODEL_ID=black-forest-labs/flux-schnell

# --- Gemini (nano banana single-pass draft image) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Slack (review cards + Approve/Reject listener) ---
SLACK_BOT_TOKEN=xoxb-your_bot_token_here
SLACK_CHANNEL=all-besque-ad-intel
SLACK_APP_TOKEN=xapp-your_app_token_here

# --- Storage backend: "local" (default) or "gcs" (production) ---
STORAGE_BACKEND=local
# For GCS (provided at kickoff):
# GCS_BUCKET=your_bucket_name
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json
